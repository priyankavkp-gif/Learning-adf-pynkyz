						"value": "{\n    \"To\": \"priyanka.vkp@gmail.com\",\n    \"Body\": {\n     \n        \"FileName\": \"@{activity('Get Metadata').output.itemName},\n        \"PipeLineName\": \"@{pipeline().Pipeline}\"\n   \n}\n}",
