		},
		"lnk_Source_adf_DB_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "pinkz"
		},
		"lnk_Target_adf_DB_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "pinkz.database.windows.net"
		},
		"lnk_Target_adf_DB_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Target-adf-DB"
		},
		"lnk_Target_adf_DB_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "pinkz"
		}
	},
